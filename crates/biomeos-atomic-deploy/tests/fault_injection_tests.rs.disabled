//! Fault injection tests for biomeos-atomic-deploy
//!
//! Systematic testing of error conditions and recovery

use biomeos_atomic_deploy::*;
use std::path::PathBuf;
use tempfile::TempDir;

/// Fault: USB seed missing
#[test]
fn fault_missing_usb_seed() {
    let temp_dir = TempDir::new().unwrap();
    let nonexistent_seed = temp_dir.path().join("nonexistent.seed");

    let config = DeploymentConfig::test_config(nonexistent_seed.clone());

    // Config should be created successfully
    assert_eq!(config.usb_seed_path, nonexistent_seed);

    // But seed doesn't exist
    assert!(!config.usb_seed_path.exists());
}

/// Fault: Invalid binary directory
#[test]
fn fault_invalid_binary_directory() {
    let bad_path = PathBuf::from("/this/path/does/not/exist");
    let runtime_dir = PathBuf::from("/tmp");

    let result = PrimalLauncher::new(bad_path, runtime_dir);

    assert!(result.is_err());
    let error_msg = result.unwrap_err().to_string();
    assert!(error_msg.contains("Binary directory not found"));
}

/// Fault: Socket creation failure (path too long)
#[test]
fn fault_socket_path_too_long() {
    // Unix socket paths are limited to ~108 characters
    let very_long_path = "/tmp/".to_string() + &"x".repeat(200) + ".sock";
    let path = PathBuf::from(very_long_path);

    // This should fail when attempting to create socket
    let result = std::os::unix::net::UnixListener::bind(&path);
    assert!(result.is_err());
}

/// Fault: Process spawn failure (bad binary)
#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn fault_bad_binary() {
    let temp_dir = TempDir::new().unwrap();
    let binary_dir = temp_dir.path().join("bin");
    let runtime_dir = temp_dir.path().join("runtime");

    std::fs::create_dir(&binary_dir).unwrap();

    // Create a non-executable file
    let fake_binary = binary_dir.join("primals").join("fake-primal");
    std::fs::create_dir_all(fake_binary.parent().unwrap()).unwrap();
    std::fs::write(&fake_binary, "not executable").unwrap();

    let mut launcher = PrimalLauncher::new(binary_dir, runtime_dir).unwrap();

    let mut env = std::collections::HashMap::new();
    env.insert("FAKE_SOCKET".to_string(), "/tmp/fake.sock".to_string());

    // Should fail to launch
    let result = launcher.launch("fake-primal", env).await;
    assert!(result.is_err());
}

/// Fault: Disk full simulation (write failure)
#[test]
fn fault_disk_full() {
    // Simulate by trying to write to read-only location
    let read_only_path = PathBuf::from("/dev/null/cannot_write_here");
    let result = std::fs::write(&read_only_path, "test");

    // Should fail
    assert!(result.is_err());
}

/// Fault: Health check timeout
#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn fault_socket_never_appears() {
    let temp_dir = TempDir::new().unwrap();
    let binary_dir = temp_dir.path().join("bin");
    let runtime_dir = temp_dir.path().join("runtime");

    std::fs::create_dir(&binary_dir).unwrap();

    let launcher = PrimalLauncher::new(binary_dir, runtime_dir).unwrap();

    let socket_path = temp_dir.path().join("never_appears.sock");

    // Should timeout waiting for socket
    let result = launcher
        .wait_for_socket(&socket_path, tokio::time::Duration::from_millis(100))
        .await;
    assert!(result.is_err());
    assert!(result.unwrap_err().to_string().contains("Timeout"));
}

/// Fault: Corrupted socket file
#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn fault_corrupted_socket() {
    let temp_dir = TempDir::new().unwrap();
    let checker = HealthChecker::new(temp_dir.path().to_path_buf());

    let socket_path = temp_dir.path().join("corrupted.sock");

    // Create a regular file instead of socket
    std::fs::write(&socket_path, "I am not a socket").unwrap();

    let status = checker.check_primal(&socket_path).await.unwrap();

    assert!(!status.is_healthy);
    assert!(status.socket_exists);
    assert!(!status.socket_accessible);
}

/// Fault: Concurrent access to same socket
#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn fault_concurrent_socket_access() {
    use std::os::unix::net::UnixListener;

    let temp_dir = TempDir::new().unwrap();
    let socket_path = temp_dir.path().join("concurrent.sock");

    // First binding succeeds
    let _listener1 = UnixListener::bind(&socket_path).unwrap();

    // Second binding to same path should fail
    let result = UnixListener::bind(&socket_path);
    assert!(result.is_err());
}

/// Fault: Process termination mid-deployment
#[test]
fn fault_process_died() {
    let instance = PrimalInstance {
        primal_name: "dead-process".to_string(),
        pid: 999999, // PID that doesn't exist
        socket_path: PathBuf::from("/tmp/dead.sock"),
        started_at: chrono::Utc::now(),
    };

    // Should detect process is not running
    assert!(!instance.is_running());
}

/// Fault: Invalid family ID
#[test]
fn fault_invalid_family_id() {
    let temp_dir = TempDir::new().unwrap();
    let mut config = DeploymentConfig::test_config(temp_dir.path().join("test.seed"));

    // Test various invalid family IDs
    config.family_id = "".to_string();
    assert!(config.family_id.is_empty());

    config.family_id = "invalid chars!@#$".to_string();
    // Should still be settable (validation happens elsewhere)
    assert!(!config.family_id.is_empty());
}

/// Fault: Deployment batch overflow
#[test]
fn fault_deployment_batch_edge_cases() {
    let temp_dir = TempDir::new().unwrap();
    let mut config = DeploymentConfig::test_config(temp_dir.path().join("test.seed"));

    // Empty batch
    config.deployment_batch = "".to_string();
    let json = serde_json::to_string(&config).unwrap();
    let _: DeploymentConfig = serde_json::from_str(&json).unwrap();

    // Very long batch
    config.deployment_batch = "x".repeat(1000);
    let json = serde_json::to_string(&config).unwrap();
    let deserialized: DeploymentConfig = serde_json::from_str(&json).unwrap();
    assert_eq!(deserialized.deployment_batch.len(), 1000);
}

/// Fault: Binary not found
#[test]
fn fault_binary_not_found() {
    let temp_dir = TempDir::new().unwrap();
    let binary_dir = temp_dir.path().join("bin");
    let runtime_dir = temp_dir.path().join("runtime");

    std::fs::create_dir(&binary_dir).unwrap();

    let launcher = PrimalLauncher::new(binary_dir, runtime_dir).unwrap();

    let result = launcher.find_binary("nonexistent-primal");
    assert!(result.is_err());
    assert!(result.unwrap_err().to_string().contains("Binary not found"));
}

/// Fault: Multiple errors in deployment
#[test]
fn fault_multiple_deployment_errors() {
    let mut result = DeploymentResult {
        tower: None,
        node: None,
        nest: None,
        success_count: 0,
        errors: Vec::new(),
    };

    // Accumulate multiple errors
    result
        .errors
        .push("Tower deployment failed: seed missing".to_string());
    result
        .errors
        .push("Node deployment failed: binary not found".to_string());
    result
        .errors
        .push("Nest deployment failed: permission denied".to_string());

    assert_eq!(result.errors.len(), 3);
    assert!(!result.is_success());
    assert_eq!(result.success_count, 0);
}

/// Fault: Health check on deleted socket
#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn fault_socket_deleted_during_check() {
    use std::os::unix::net::UnixListener;

    let temp_dir = TempDir::new().unwrap();
    let checker = HealthChecker::new(temp_dir.path().to_path_buf());
    let socket_path = temp_dir.path().join("temporary.sock");

    // Create socket
    let listener = UnixListener::bind(&socket_path).unwrap();

    // Verify it's healthy
    let status = checker.check_primal(&socket_path).await.unwrap();
    assert!(status.is_healthy);

    // Delete socket
    drop(listener);
    std::fs::remove_file(&socket_path).unwrap();

    // Now should be unhealthy
    let status = checker.check_primal(&socket_path).await.unwrap();
    assert!(!status.is_healthy);
}

/// Fault: JSON deserialization with missing fields
#[test]
fn fault_incomplete_json_data() {
    // Missing required fields
    let bad_configs = vec![
        r#"{}"#,
        r#"{"family_id": "test"}"#,
        r#"{"usb_seed_path": "/tmp/test.seed"}"#,
    ];

    for bad_json in bad_configs {
        let result: Result<DeploymentConfig, _> = serde_json::from_str(bad_json);
        assert!(
            result.is_err(),
            "Should reject incomplete JSON: {}",
            bad_json
        );
    }
}

/// Fault: Race condition in socket creation
#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn fault_socket_creation_race() {
    use std::os::unix::net::UnixListener;
    use tokio::time::{sleep, Duration};

    let temp_dir = TempDir::new().unwrap();
    let socket_path = temp_dir.path().join("race.sock");

    // Spawn two tasks trying to create the same socket
    let path1 = socket_path.clone();
    let handle1 = tokio::spawn(async move {
        sleep(Duration::from_millis(10)).await;
        UnixListener::bind(&path1)
    });

    let path2 = socket_path.clone();
    let handle2 = tokio::spawn(async move {
        sleep(Duration::from_millis(10)).await;
        UnixListener::bind(&path2)
    });

    let result1 = handle1.await.unwrap();
    let result2 = handle2.await.unwrap();

    // One should succeed, one should fail
    let success_count = [result1.is_ok(), result2.is_ok()]
        .iter()
        .filter(|&&x| x)
        .count();

    assert_eq!(
        success_count, 1,
        "Exactly one socket creation should succeed"
    );
}
