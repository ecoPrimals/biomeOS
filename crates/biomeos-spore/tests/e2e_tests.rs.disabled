//! End-to-end tests for complete spore lifecycle

use biomeos_spore::{setup_test_binaries, Spore, SporeConfig, SporeType, SporeVerification};
use tempfile::TempDir;

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_complete_spore_lifecycle_live() {
    // Setup mock binaries for testing
    setup_test_binaries().expect("Failed to setup test binaries");
    let temp_dir = TempDir::new().unwrap();

    // Step 1: Create LiveSpore
    let config = SporeConfig {
        label: "e2e_live_test".to_string(),
        node_id: "tower_e2e".to_string(),
        spore_type: SporeType::Live,
    };

    let spore = Spore::create(temp_dir.path().to_path_buf(), config.clone()).await;
    assert!(
        spore.is_ok(),
        "Spore creation should succeed: {:?}",
        spore.as_ref().err()
    );

    let spore = spore.unwrap();
    assert_eq!(spore.config().label, config.label);
    assert_eq!(spore.config().node_id, config.node_id);
    assert_eq!(spore.config().spore_type, SporeType::Live);

    // Step 2: Verify spore structure
    let root = spore.root_path();
    assert!(root.exists());
    assert!(root.join(".family.seed").exists());
    assert!(root.join("tower.toml").exists());
    assert!(root.join("README.md").exists());
    assert!(root.join(".spore.json").exists());
    assert!(root.join("deploy.sh").exists()); // LiveSpore has deploy.sh

    // Step 3: Verify genetic material directories
    assert!(root.join("bin").exists());
    assert!(root.join("primals").exists());
    assert!(root.join("primals/certs").exists());

    // Step 4: Verify tower.toml content
    let tower_config = std::fs::read_to_string(root.join("tower.toml")).unwrap();
    assert!(tower_config.contains("tower_e2e"));
    assert!(tower_config.contains("beardog-server"));
    assert!(tower_config.contains("songbird"));

    // Step 5: Verify spore can be loaded
    let loaded_spore = Spore::from_path(temp_dir.path().to_path_buf());
    assert!(loaded_spore.is_ok());
}

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_complete_spore_lifecycle_cold() {
    setup_test_binaries().expect("Failed to setup test binaries");
    let temp_dir = TempDir::new().unwrap();

    // Step 1: Create ColdSpore
    let config = SporeConfig {
        label: "e2e_cold_test".to_string(),
        node_id: "tower_cold_e2e".to_string(),
        spore_type: SporeType::Cold,
    };

    let spore = Spore::create(temp_dir.path().to_path_buf(), config.clone()).await;
    assert!(spore.is_ok());

    let spore = spore.unwrap();

    // Step 2: Verify ColdSpore differences
    let root = spore.root_path();
    assert!(!root.join("deploy.sh").exists()); // ColdSpore has NO deploy.sh

    // Step 3: Verify README mentions storage
    let readme = std::fs::read_to_string(root.join("README.md")).unwrap();
    assert!(readme.contains("ColdSpore"));
    assert!(readme.contains("storage"));
    assert!(readme.contains("archive"));

    // Step 4: Verify manifest shows cold type
    let manifest = std::fs::read_to_string(root.join(".spore.json")).unwrap();
    assert!(
        manifest.contains("\"spore_type\":\"Cold\"")
            || manifest.contains("\"spore_type\": \"Cold\"")
    );
}

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_sibling_spore_creation() {
    setup_test_binaries().expect("Failed to setup test binaries");
    let parent_dir = TempDir::new().unwrap();
    let sibling_dir = TempDir::new().unwrap();

    // Step 1: Create parent spore
    let parent_config = SporeConfig {
        label: "parent_spore".to_string(),
        node_id: "tower_parent".to_string(),
        spore_type: SporeType::Live,
    };

    let parent = Spore::create(parent_dir.path().to_path_buf(), parent_config)
        .await
        .unwrap();

    // Step 2: Clone to create sibling
    let sibling_config = SporeConfig {
        label: "sibling_spore".to_string(),
        node_id: "tower_sibling".to_string(),
        spore_type: SporeType::Live, // Inherited
    };

    let sibling = parent
        .clone_sibling(sibling_dir.path().to_path_buf(), sibling_config)
        .await;

    assert!(sibling.is_ok());

    let sibling = sibling.unwrap();

    // Step 3: Verify both have same family seed
    let parent_seed_path = parent.root_path().join(".family.seed");
    let sibling_seed_path = sibling.root_path().join(".family.seed");

    let parent_seed = std::fs::read(&parent_seed_path).unwrap();
    let sibling_seed = std::fs::read(&sibling_seed_path).unwrap();

    assert_eq!(
        parent_seed, sibling_seed,
        "Siblings should have same family seed"
    );

    // Step 4: Verify different node IDs in config
    let parent_config_str = std::fs::read_to_string(parent.root_path().join("tower.toml")).unwrap();
    let sibling_config_str =
        std::fs::read_to_string(sibling.root_path().join("tower.toml")).unwrap();

    assert!(parent_config_str.contains("tower_parent"));
    assert!(sibling_config_str.contains("tower_sibling"));
}

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_spore_verification() {
    setup_test_binaries().expect("Failed to setup test binaries");
    let temp_dir = TempDir::new().unwrap();

    // Create a spore
    let config = SporeConfig {
        label: "verify_test".to_string(),
        node_id: "tower_verify".to_string(),
        spore_type: SporeType::Live,
    };

    let _ = Spore::create(temp_dir.path().to_path_buf(), config)
        .await
        .unwrap();

    // Verify it
    let verification = SporeVerification::verify(temp_dir.path()).await;
    assert!(verification.is_ok());

    let result = verification.unwrap();

    // Should have checks for critical files
    let checks = &result.checks;
    assert!(!checks.is_empty());

    // At minimum should check for:
    // - .family.seed
    // - tower.toml
    // - directory structure
}

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_multiple_spores_independent() {
    setup_test_binaries().expect("Failed to setup test binaries");
    let dir1 = TempDir::new().unwrap();
    let dir2 = TempDir::new().unwrap();

    // Create two independent spores
    let config1 = SporeConfig {
        label: "spore1".to_string(),
        node_id: "tower1".to_string(),
        spore_type: SporeType::Live,
    };

    let config2 = SporeConfig {
        label: "spore2".to_string(),
        node_id: "tower2".to_string(),
        spore_type: SporeType::Cold,
    };

    let spore1 = Spore::create(dir1.path().to_path_buf(), config1)
        .await
        .unwrap();
    let spore2 = Spore::create(dir2.path().to_path_buf(), config2)
        .await
        .unwrap();

    // Verify they have different family seeds
    let seed1 = std::fs::read(spore1.root_path().join(".family.seed")).unwrap();
    let seed2 = std::fs::read(spore2.root_path().join(".family.seed")).unwrap();

    assert_ne!(
        seed1, seed2,
        "Independent spores should have different family seeds"
    );

    // Verify they have different types
    assert_eq!(spore1.config().spore_type, SporeType::Live);
    assert_eq!(spore2.config().spore_type, SporeType::Cold);
}

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_deploy_script_executable() {
    setup_test_binaries().expect("Failed to setup test binaries");
    let temp_dir = TempDir::new().unwrap();

    let config = SporeConfig {
        label: "exec_test".to_string(),
        node_id: "tower_exec".to_string(),
        spore_type: SporeType::Live,
    };

    let spore = Spore::create(temp_dir.path().to_path_buf(), config)
        .await
        .unwrap();

    let deploy_script = spore.root_path().join("deploy.sh");
    assert!(deploy_script.exists());

    // Verify it's a shell script
    let content = std::fs::read_to_string(&deploy_script).unwrap();
    assert!(content.starts_with("#!/usr/bin/env bash"));

    // Verify it has FAT32 handling
    assert!(content.contains("FAT32"));
    assert!(content.contains("chmod"));
}
