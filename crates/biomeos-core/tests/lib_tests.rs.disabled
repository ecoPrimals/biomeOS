//! Unit tests for the biomeos-core lib.rs main configuration types

use biomeos_core::*;
use std::collections::HashMap;

#[test]
fn test_biomeos_version_constant() {
    assert!(!BIOMEOS_VERSION.is_empty());
    assert!(BIOMEOS_VERSION.contains('.'));
}

#[test]
fn test_biome_id_creation() {
    let id1 = BiomeId::new_v4();
    let id2 = BiomeId::new_v4();
    
    assert_ne!(id1, id2);
    assert_eq!(id1.to_string().len(), 36); // UUID v4 format
    assert_eq!(id2.to_string().len(), 36);
}

#[test]
fn test_primal_id_creation() {
    let id1: PrimalId = "test-primal-1".to_string();
    let id2: PrimalId = "test-primal-2".to_string();
    
    assert_ne!(id1, id2);
    assert_eq!(id1, "test-primal-1");
    assert_eq!(id2, "test-primal-2");
}

#[test]
fn test_biome_result_ok() {
    let result: BiomeResult<String> = Ok("success".to_string());
    assert!(result.is_ok());
    assert_eq!(result.unwrap(), "success");
}

#[test]
fn test_biome_result_err() {
    let result: BiomeResult<String> = Err(BiomeError::Config("test error".to_string()));
    assert!(result.is_err());
    
    match result.unwrap_err() {
        BiomeError::Config(msg) => assert_eq!(msg, "test error"),
        _ => panic!("Expected Config error"),
    }
}

#[test]
fn test_global_config_default() {
    let config = GlobalConfig {
        instance_name: "test-instance".to_string(),
        data_dir: "/tmp/test".to_string(),
        log_level: "debug".to_string(),
        dev_mode: true,
        telemetry: TelemetryConfig {
            enabled: false,
            endpoint: Some("http://localhost:8080".to_string()),
            interval_secs: 30,
        },
    };
    
    assert_eq!(config.instance_name, "test-instance");
    assert_eq!(config.data_dir, "/tmp/test");
    assert_eq!(config.log_level, "debug");
    assert!(config.dev_mode);
    assert!(!config.telemetry.enabled);
    assert_eq!(config.telemetry.endpoint, Some("http://localhost:8080".to_string()));
    assert_eq!(config.telemetry.interval_secs, 30);
}

#[test]
fn test_telemetry_config_creation() {
    let telemetry = TelemetryConfig {
        enabled: true,
        endpoint: None,
        interval_secs: 120,
    };
    
    assert!(telemetry.enabled);
    assert!(telemetry.endpoint.is_none());
    assert_eq!(telemetry.interval_secs, 120);
}

#[test]
fn test_network_config_creation() {
    let network = NetworkConfig {
        interface: "192.168.1.1".to_string(),
        port_ranges: vec![(8000, 8010), (9000, 9010)],
        ipv6_enabled: true,
    };
    
    assert_eq!(network.interface, "192.168.1.1");
    assert_eq!(network.port_ranges.len(), 2);
    assert_eq!(network.port_ranges[0], (8000, 8010));
    assert_eq!(network.port_ranges[1], (9000, 9010));
    assert!(network.ipv6_enabled);
}

#[test]
fn test_biomeos_config_default() {
    let config = BiomeOSConfig::default();
    
    assert_eq!(config.global.instance_name, "default-biome");
    assert_eq!(config.global.data_dir, "/var/lib/biomeos");
    assert_eq!(config.global.log_level, "info");
    assert!(!config.global.dev_mode);
    assert!(config.global.telemetry.enabled);
    assert!(config.global.telemetry.endpoint.is_none());
    assert_eq!(config.global.telemetry.interval_secs, 60);
    
    assert!(config.primals.is_empty());
    
    assert_eq!(config.networking.interface, "0.0.0.0");
    assert_eq!(config.networking.port_ranges.len(), 2);
    assert_eq!(config.networking.port_ranges[0], (8080, 8080));
    assert_eq!(config.networking.port_ranges[1], (8443, 8443));
    assert!(!config.networking.ipv6_enabled);
}

#[test]
fn test_biomeos_config_custom() {
    let mut config = BiomeOSConfig::default();
    config.global.instance_name = "custom-biome".to_string();
    config.global.dev_mode = true;
    config.networking.ipv6_enabled = true;
    
    // Add a primal configuration using string type
    config.primals.insert(
        "songbird".to_string(),
        GlobalConfig {
            instance_name: "songbird-instance".to_string(),
            data_dir: "/tmp/songbird".to_string(),
            log_level: "debug".to_string(),
            dev_mode: true,
            telemetry: TelemetryConfig {
                enabled: true,
                endpoint: Some("http://telemetry.local".to_string()),
                interval_secs: 45,
            },
        },
    );
    
    assert_eq!(config.global.instance_name, "custom-biome");
    assert!(config.global.dev_mode);
    assert!(config.networking.ipv6_enabled);
    assert_eq!(config.primals.len(), 1);
    assert!(config.primals.contains_key("songbird"));
    
    let songbird_config = config.primals.get("songbird").unwrap();
    assert_eq!(songbird_config.instance_name, "songbird-instance");
    assert_eq!(songbird_config.data_dir, "/tmp/songbird");
}

#[test]
fn test_biome_error_variants() {
    let errors = vec![
        BiomeError::Config("config error".to_string()),
        BiomeError::Primal("primal error".to_string()),
        BiomeError::PrimalNotFound("missing-primal".to_string()),
        BiomeError::Networking("network error".to_string()),
        BiomeError::Security("security error".to_string()),
        BiomeError::Storage("storage error".to_string()),
        BiomeError::Cloud("cloud error".to_string()),
        BiomeError::Compute("compute error".to_string()),
        BiomeError::Orchestration("orchestration error".to_string()),
        BiomeError::CryptoLock("crypto lock error".to_string()),
        BiomeError::UniversalPlatform("platform error".to_string()),
        BiomeError::Installation("installation error".to_string()),
        BiomeError::SovereigntyViolation("sovereignty error".to_string()),
        BiomeError::VendorLock("vendor lock error".to_string()),
        BiomeError::ComplianceViolation {
            severity: "high".to_string(),
            message: "compliance error".to_string(),
        },
        BiomeError::Initialization("init error".to_string()),
        BiomeError::HealthCheck("health error".to_string()),
        BiomeError::Timeout("timeout error".to_string()),
        BiomeError::Unknown("unknown error".to_string()),
        BiomeError::Generic { message: "generic error".to_string() },
    ];
    
    assert_eq!(errors.len(), 20);
    
    for error in errors {
        let error_str = error.to_string();
        assert!(!error_str.is_empty());
        assert!(error_str.contains("error"));
    }
}

#[test]
fn test_biome_error_compliance_violation() {
    let error = BiomeError::ComplianceViolation {
        severity: "critical".to_string(),
        message: "GDPR violation detected".to_string(),
    };
    
    let error_str = error.to_string();
    assert!(error_str.contains("critical"));
    assert!(error_str.contains("GDPR violation detected"));
}

#[test]
fn test_universal_biome_config_default() {
    let config = UniversalBiomeConfig::default();
    
    // Test that default values are set
    assert_eq!(config.biome.metadata.name, "default-biome");
    assert!(config.biome.primals.is_empty());
    
    // Test platform config exists
    assert_eq!(config.platform.energy_flow_state, EnergyFlowState::Closed);
    
    // Test crypto locks config has minimal compliance
    assert_eq!(config.crypto_locks.compliance_level, ComplianceLevel::Minimal);
    
    // Test provider config
    assert_eq!(config.providers.cloud.default_provider, CloudProviderType::Local);
    assert_eq!(config.providers.compute.default_provider, ComputeProviderType::Local);
    assert_eq!(config.providers.orchestration.default_orchestrator, OrchestratorType::Local);
    assert_eq!(config.providers.crypto.default_provider, CryptoProvider::Local);
}

#[test]
fn test_universal_platform_config_creation() {
    let config = UniversalPlatformConfig {
        deployment: DeploymentConfig {
            mode: "standard".to_string(),
            target_platform: "linux".to_string(),
            installation_directory: "/opt/biomeos".to_string(),
            auto_configure: true,
            create_desktop_shortcuts: false,
        },
        energy_flow_state: EnergyFlowState::CommercialOpen,
        ai_personality: AiPersonalityConfig {
            personality_type: "helpful".to_string(),
            learning_enabled: true,
            adaptation_speed: 0.8,
            user_preferences: HashMap::new(),
        },
        commercial_model: CommercialModel::UserChoice,
        partnership_config: PartnershipConfig {
            gen1_endpoint: Some("https://api.example.com".to_string()),
            gen2_rhizo_enabled: false,
            access_priority: AccessPriority::Humanity,
            inverse_scaling: InverseScaleConfig {
                enabled: true,
                small_business_threshold: BusinessThreshold {
                    max_employees: 50,
                    max_revenue_usd: 10_000_000,
                },
                enterprise_threshold: BusinessThreshold {
                    max_employees: 100_000,
                    max_revenue_usd: 1_000_000_000,
                },
                cost_multipliers: BusinessCostMultipliers {
                    small_business: 1.0,
                    medium_business: 2.0,
                    large_business: 5.0,
                    enterprise: 10.0,
                },
                good_faith_model: true,
            },
            partnership_benefits: vec!["priority_support".to_string()],
        },
        sovereignty_level: SovereigntyLevel::High,
    };
    
    assert_eq!(config.deployment.mode, "standard");
    assert!(matches!(config.energy_flow_state, EnergyFlowState::CommercialOpen));
    assert_eq!(config.ai_personality.personality_type, "helpful");
    assert!(config.ai_personality.learning_enabled);
    assert_eq!(config.ai_personality.adaptation_speed, 0.8);
    assert!(matches!(config.commercial_model, CommercialModel::UserChoice));
    assert!(matches!(config.partnership_config.access_priority, AccessPriority::Humanity));
    assert!(matches!(config.sovereignty_level, SovereigntyLevel::High));
}

#[test]
fn test_crypto_lock_config_creation() {
    let config = CryptoLockConfig {
        compliance_level: ComplianceLevel::Maximum,
        licensing: LicensingConfig {
            personal_use: PersonalUseConfig {
                ai_cat_door_enabled: true,
                personal_ai_limits: PersonalAiLimits {
                    max_daily_requests: 1000,
                    max_monthly_data_gb: 50.0,
                    max_concurrent_connections: 10,
                    cost_limit_usd: 100.0,
                },
                current_usage: CurrentUsage {
                    daily_requests: 250,
                    monthly_data_gb: 15.5,
                    concurrent_connections: 3,
                    peak_usage_time: chrono::Utc::now(),
                    cost_current_month: 25.75,
                },
            },
            commercial_use: CommercialUseConfig {
                partnership_access: true,
                gen1_endpoint: Some("https://partner.api".to_string()),
                inverse_scaling: true,
                good_faith_model: true,
            },
        },
        biome_config: BiomeConfiguration {
            energy_flow_state: EnergyFlowState::PrivateOpen,
            sovereignty_level: SovereigntyLevel::Maximum,
            ai_cat_door_enabled: true,
            compliance_frameworks: vec!["GDPR".to_string(), "CCPA".to_string()],
            geographic_restrictions: vec!["EU".to_string()],
        },
    };
    
    assert!(matches!(config.compliance_level, ComplianceLevel::Maximum));
    assert!(config.licensing.personal_use.ai_cat_door_enabled);
    assert_eq!(config.licensing.personal_use.personal_ai_limits.max_daily_requests, 1000);
    assert_eq!(config.licensing.personal_use.personal_ai_limits.max_monthly_data_gb, 50.0);
    assert_eq!(config.licensing.personal_use.current_usage.daily_requests, 250);
    assert_eq!(config.licensing.personal_use.current_usage.monthly_data_gb, 15.5);
    assert_eq!(config.biome_config.compliance_frameworks.len(), 2);
    assert_eq!(config.biome_config.geographic_restrictions.len(), 1);
}

#[test]
fn test_commercial_model_variants() {
    let models = vec![
        CommercialModel::LicensingOnly,
        CommercialModel::PartnershipAccess,
        CommercialModel::UserChoice,
        CommercialModel::FullyOpen,
    ];
    
    assert_eq!(models.len(), 4);
    assert!(matches!(models[0], CommercialModel::LicensingOnly));
    assert!(matches!(models[1], CommercialModel::PartnershipAccess));
    assert!(matches!(models[2], CommercialModel::UserChoice));
    assert!(matches!(models[3], CommercialModel::FullyOpen));
}

#[test]
fn test_access_priority_variants() {
    let priorities = vec![
        AccessPriority::Sovereign,
        AccessPriority::Humanity,
        AccessPriority::Companies,
        AccessPriority::Governments,
    ];
    
    assert_eq!(priorities.len(), 4);
    assert!(matches!(priorities[0], AccessPriority::Sovereign));
    assert!(matches!(priorities[1], AccessPriority::Humanity));
    assert!(matches!(priorities[2], AccessPriority::Companies));
    assert!(matches!(priorities[3], AccessPriority::Governments));
}

#[test]
fn test_sovereignty_level_variants() {
    let levels = vec![
        SovereigntyLevel::Maximum,
        SovereigntyLevel::High,
        SovereigntyLevel::Medium,
        SovereigntyLevel::Low,
        SovereigntyLevel::Minimal,
    ];
    
    assert_eq!(levels.len(), 5);
    assert!(matches!(levels[0], SovereigntyLevel::Maximum));
    assert!(matches!(levels[1], SovereigntyLevel::High));
    assert!(matches!(levels[2], SovereigntyLevel::Medium));
    assert!(matches!(levels[3], SovereigntyLevel::Low));
    assert!(matches!(levels[4], SovereigntyLevel::Minimal));
}

#[test]
fn test_universal_biome_manager_creation() {
    let config = BiomeOSConfig::default();
    let manager = UniversalBiomeManager::new(config);
    
    // Test that manager is created with default values
    assert_eq!(manager.config.platform.energy_flow_state, EnergyFlowState::Closed);
    assert_eq!(manager.config.crypto_locks.compliance_level, ComplianceLevel::Minimal);
}

#[test]
fn test_universal_biome_manager_from_universal_config() {
    let config = UniversalBiomeConfig::default();
    let manager = UniversalBiomeManager::new_from_universal_config(config);
    
    // Test that manager is created with the given config
    assert_eq!(manager.config.platform.energy_flow_state, EnergyFlowState::Closed);
    assert_eq!(manager.config.crypto_locks.compliance_level, ComplianceLevel::Minimal);
}

#[test]
fn test_universal_biome_manager_sovereignty_score() {
    let config = BiomeOSConfig::default();
    let manager = UniversalBiomeManager::new(config);
    
    let score = manager.calculate_sovereignty_score();
    assert_eq!(score, 3.0); // biomeOS starts with high sovereignty
}

#[test]
fn test_service_registration_creation() {
    let registration = ServiceRegistration {
        service_name: "test-service".to_string(),
        primal_type: "songbird".to_string(),
        runtime: RuntimeType::Container,
        internal_address: "10.42.0.5:8000".to_string(),
        public_routes: vec!["/api/v1/test".to_string()],
        health_check_url: "http://10.42.0.5:8000/health".to_string(),
        metadata: HashMap::new(),
        biome_id: "test-biome-id".to_string(),
        capabilities: ServiceCapabilities {
            core: vec!["service-discovery".to_string()],
            extended: vec!["load-balancing".to_string()],
            integrations: vec!["nestgate".to_string()],
        },
    };
    
    assert_eq!(registration.service_name, "test-service");
    assert_eq!(registration.primal_type, "songbird");
    assert_eq!(registration.runtime, RuntimeType::Container);
    assert_eq!(registration.internal_address, "10.42.0.5:8000");
    assert_eq!(registration.public_routes.len(), 1);
    assert_eq!(registration.public_routes[0], "/api/v1/test");
    assert_eq!(registration.health_check_url, "http://10.42.0.5:8000/health");
    assert_eq!(registration.biome_id, "test-biome-id");
    assert_eq!(registration.capabilities.core.len(), 1);
    assert_eq!(registration.capabilities.extended.len(), 1);
    assert_eq!(registration.capabilities.integrations.len(), 1);
}

#[test]
fn test_runtime_type_variants() {
    let runtimes = vec![
        RuntimeType::Wasm,
        RuntimeType::Container,
        RuntimeType::Native,
        RuntimeType::Gpu,
        RuntimeType::Agent,
    ];
    
    assert_eq!(runtimes.len(), 5);
    assert!(matches!(runtimes[0], RuntimeType::Wasm));
    assert!(matches!(runtimes[1], RuntimeType::Container));
    assert!(matches!(runtimes[2], RuntimeType::Native));
    assert!(matches!(runtimes[3], RuntimeType::Gpu));
    assert!(matches!(runtimes[4], RuntimeType::Agent));
}

#[test]
fn test_compliance_status_variants() {
    let statuses = vec![
        ComplianceStatus::FullyCompliant,
        ComplianceStatus::PartiallyCompliant,
        ComplianceStatus::NonCompliant,
        ComplianceStatus::Unknown,
    ];
    
    assert_eq!(statuses.len(), 4);
    assert!(matches!(statuses[0], ComplianceStatus::FullyCompliant));
    assert!(matches!(statuses[1], ComplianceStatus::PartiallyCompliant));
    assert!(matches!(statuses[2], ComplianceStatus::NonCompliant));
    assert!(matches!(statuses[3], ComplianceStatus::Unknown));
}

#[test]
fn test_biome_resource_requirements_creation() {
    let requirements = BiomeResourceRequirements {
        cpu_cores: Some(4.0),
        memory_mb: Some(8192),
        storage_mb: Some(51200),
        network_bandwidth_mbps: Some(1000),
        gpu_count: Some(2),
    };
    
    assert_eq!(requirements.cpu_cores, Some(4.0));
    assert_eq!(requirements.memory_mb, Some(8192));
    assert_eq!(requirements.storage_mb, Some(51200));
    assert_eq!(requirements.network_bandwidth_mbps, Some(1000));
    assert_eq!(requirements.gpu_count, Some(2));
}

#[test]
fn test_config_serialization() {
    let config = BiomeOSConfig::default();
    
    // Test JSON serialization
    let json = serde_json::to_string(&config);
    assert!(json.is_ok());
    
    // Test deserialization
    let deserialized: Result<BiomeOSConfig, _> = serde_json::from_str(&json.unwrap());
    assert!(deserialized.is_ok());
    
    let deserialized_config = deserialized.unwrap();
    assert_eq!(deserialized_config.global.instance_name, config.global.instance_name);
    assert_eq!(deserialized_config.global.data_dir, config.global.data_dir);
    assert_eq!(deserialized_config.networking.interface, config.networking.interface);
}

#[tokio::test]
async fn test_init_biomeos() {
    let result = init_biomeos().await;
    assert!(result.is_ok());
} 