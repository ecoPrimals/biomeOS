#[test]
fn test_primal_startup_ordering() {
    let mut biome = Biome::new("startup-order-test".to_string());
    
    // Add primals with different priorities
    let high_priority = PrimalConfig {
        primal_type: PrimalType::BearDog,
        enabled: true,
        priority: 1,
        config: HashMap::new(),
    };
    
    let medium_priority = PrimalConfig {
        primal_type: PrimalType::Songbird,
        enabled: true,
        priority: 2,
        config: HashMap::new(),
    };
    
    let low_priority = PrimalConfig {
        primal_type: PrimalType::NestGate,
        enabled: true,
        priority: 3,
        config: HashMap::new(),
    };
    
    // Add in random order
    biome.add_primal("nestgate".to_string(), low_priority).unwrap();
    biome.add_primal("beardog".to_string(), high_priority).unwrap();
    biome.add_primal("songbird".to_string(), medium_priority).unwrap();
    
    // Activate and check startup order
    let result = biome.activate();
    assert!(result.is_ok());
    
    let startup_order = biome.get_startup_order();
    assert_eq!(startup_order, vec!["beardog", "songbird", "nestgate"]);
}

#[test]
fn test_biome_health_monitoring() {
    let mut biome = Biome::new("health-test".to_string());
    
    // Add primals
    let songbird_config = PrimalConfig {
        primal_type: PrimalType::Songbird,
        enabled: true,
        priority: 1,
        config: HashMap::new(),
    };
    biome.add_primal("songbird".to_string(), songbird_config).unwrap();
    
    let nestgate_config = PrimalConfig {
        primal_type: PrimalType::NestGate,
        enabled: true,
        priority: 2,
        config: HashMap::new(),
    };
    biome.add_primal("nestgate".to_string(), nestgate_config).unwrap();
    
    // Activate biome
    biome.activate().unwrap();
    
    // Check initial health
    let health = biome.health_check();
    assert!(health.is_ok());
    
    let health_status = health.unwrap();
    assert_eq!(health_status.overall_status, HealthStatus::Healthy);
    assert_eq!(health_status.primal_statuses.len(), 2);
    
    // Simulate primal failure
    biome.simulate_primal_failure("nestgate".to_string());
    
    let health = biome.health_check();
    assert!(health.is_ok());
    
    let health_status = health.unwrap();
    assert_eq!(health_status.overall_status, HealthStatus::Degraded);
    
    // Check specific primal health
    let nestgate_health = health_status.primal_statuses.get("nestgate").unwrap();
    assert_eq!(*nestgate_health, HealthStatus::Failed);
}

#[test]
fn test_biome_resource_management() {
    let mut biome = Biome::new("resource-test".to_string());
    
    // Set resource limits
    let resource_limits = ResourceLimits {
        cpu_cores: 8.0,
        memory_mb: 16384,
        storage_mb: 102400,
    };
    biome.set_resource_limits(resource_limits);
    
    // Add resource-intensive primals
    let mut toadstool_config = PrimalConfig {
        primal_type: PrimalType::Toadstool,
        enabled: true,
        priority: 1,
        config: HashMap::new(),
    };
    toadstool_config.config.insert("cpu_cores".to_string(), "4.0".to_string());
    toadstool_config.config.insert("memory_mb".to_string(), "8192".to_string());
    
    let result = biome.add_primal("toadstool".to_string(), toadstool_config);
    assert!(result.is_ok());
    
    let mut nestgate_config = PrimalConfig {
        primal_type: PrimalType::NestGate,
        enabled: true,
        priority: 2,
        config: HashMap::new(),
    };
    nestgate_config.config.insert("cpu_cores".to_string(), "3.0".to_string());
    nestgate_config.config.insert("memory_mb".to_string(), "6144".to_string());
    
    let result = biome.add_primal("nestgate".to_string(), nestgate_config);
    assert!(result.is_ok());
    
    // Check resource allocation
    let allocation = biome.get_resource_allocation();
    assert_eq!(allocation.cpu_cores, 7.0);
    assert_eq!(allocation.memory_mb, 14336);
    
    // Try to add primal that would exceed limits
    let mut heavy_config = PrimalConfig {
        primal_type: PrimalType::Squirrel,
        enabled: true,
        priority: 3,
        config: HashMap::new(),
    };
    heavy_config.config.insert("cpu_cores".to_string(), "2.0".to_string()); // Would exceed limit
    heavy_config.config.insert("memory_mb".to_string(), "4096".to_string());
    
    let result = biome.add_primal("squirrel".to_string(), heavy_config);
    assert!(result.is_err());
    
    // Verify the error is related to resource limits
    match result {
        Err(BiomeError::ResourceLimitExceeded { .. }) => (),
        _ => panic!("Expected ResourceLimitExceeded error"),
    }
}

#[test]
fn test_biome_error_handling() {
    let mut biome = Biome::new("error-test".to_string());
    
    // Test duplicate primal addition
    let config = PrimalConfig {
        primal_type: PrimalType::Songbird,
        enabled: true,
        priority: 1,
        config: HashMap::new(),
    };
    
    biome.add_primal("songbird".to_string(), config.clone()).unwrap();
    let result = biome.add_primal("songbird".to_string(), config);
    assert!(result.is_err());
    
    match result {
        Err(BiomeError::PrimalAlreadyExists { name }) => {
            assert_eq!(name, "songbird");
        }
        _ => panic!("Expected PrimalAlreadyExists error"),
    }
    
    // Test activating non-existent primal
    let result = biome.activate_primal("non-existent");
    assert!(result.is_err());
    
    match result {
        Err(BiomeError::PrimalNotFound { name }) => {
            assert_eq!(name, "non-existent");
        }
        _ => panic!("Expected PrimalNotFound error"),
    }
}

#[test]
fn test_biome_configuration_validation() {
    let mut biome = Biome::new("validation-test".to_string());
    
    // Test invalid configuration
    let mut invalid_config = PrimalConfig {
        primal_type: PrimalType::Songbird,
        enabled: true,
        priority: 1,
        config: HashMap::new(),
    };
    
    // Add invalid configuration value
    invalid_config.config.insert("invalid_mode".to_string(), "unknown".to_string());
    
    let result = biome.add_primal("songbird".to_string(), invalid_config);
    // For now, we accept invalid configs but validate on activation
    assert!(result.is_ok());
    
    // Test validation during activation
    let result = biome.activate();
    assert!(result.is_err());
    
    match result {
        Err(BiomeError::ConfigurationError { .. }) => (),
        _ => panic!("Expected ConfigurationError"),
    }
}

#[test]
fn test_gaming_tournament_scenario() {
    let mut biome = Biome::new("gaming-tournament".to_string());
    
    // Add Toadstool for hosting Songbird
    let mut toadstool_config = PrimalConfig {
        primal_type: PrimalType::Toadstool,
        enabled: true,
        priority: 1,
        config: HashMap::new(),
    };
    toadstool_config.config.insert("mode".to_string(), "host".to_string());
    toadstool_config.config.insert("cpu_cores".to_string(), "4.0".to_string());
    toadstool_config.config.insert("memory_mb".to_string(), "16384".to_string());
    
    biome.add_primal("toadstool".to_string(), toadstool_config).unwrap();
    
    // Add Songbird for orchestration
    let mut songbird_config = PrimalConfig {
        primal_type: PrimalType::Songbird,
        enabled: true,
        priority: 2,
        config: HashMap::new(),
    };
    songbird_config.config.insert("mode".to_string(), "orchestrator".to_string());
    songbird_config.config.insert("topology".to_string(), "ring".to_string());
    songbird_config.config.insert("depends_on".to_string(), "toadstool".to_string());
    
    biome.add_primal("songbird".to_string(), songbird_config).unwrap();
    
    // Add Physics Toadstool
    let mut physics_config = PrimalConfig {
        primal_type: PrimalType::Toadstool,
        enabled: true,
        priority: 3,
        config: HashMap::new(),
    };
    physics_config.config.insert("mode".to_string(), "compute".to_string());
    physics_config.config.insert("specialization".to_string(), "physics".to_string());
    physics_config.config.insert("cpu_cores".to_string(), "32.0".to_string());
    physics_config.config.insert("memory_mb".to_string(), "131072".to_string());
    physics_config.config.insert("depends_on".to_string(), "songbird".to_string());
    
    biome.add_primal("physics-toadstool".to_string(), physics_config).unwrap();
    
    // Set appropriate resource limits
    let resource_limits = ResourceLimits {
        cpu_cores: 64.0,
        memory_mb: 262144,
        storage_mb: 1048576,
    };
    biome.set_resource_limits(resource_limits);
    
    // Activate the tournament infrastructure
    let result = biome.activate();
    assert!(result.is_ok());
    
    // Verify all primals are active
    assert!(biome.primal_active("toadstool"));
    assert!(biome.primal_active("songbird"));
    assert!(biome.primal_active("physics-toadstool"));
    
    // Check startup order (dependencies resolved)
    let startup_order = biome.get_startup_order();
    assert_eq!(startup_order[0], "toadstool"); // First
    assert_eq!(startup_order[1], "songbird");  // Depends on toadstool
    assert_eq!(startup_order[2], "physics-toadstool"); // Depends on songbird
    
    // Verify resource allocation
    let allocation = biome.get_resource_allocation();
    assert_eq!(allocation.cpu_cores, 36.0); // 4 + 32
    assert_eq!(allocation.memory_mb, 147456); // 16384 + 131072
    
    // Test health monitoring
    let health = biome.health_check().unwrap();
    assert_eq!(health.overall_status, HealthStatus::Healthy);
    assert_eq!(health.primal_statuses.len(), 3);
}

#[test]
fn test_recursive_biome_management() {
    let mut parent_biome = Biome::new("parent-biome".to_string());
    
    // Create child biomes
    let mut child_biome_1 = Biome::new("child-biome-1".to_string());
    let songbird_config = PrimalConfig {
        primal_type: PrimalType::Songbird,
        enabled: true,
        priority: 1,
        config: HashMap::new(),
    };
    child_biome_1.add_primal("songbird".to_string(), songbird_config).unwrap();
    
    let mut child_biome_2 = Biome::new("child-biome-2".to_string());
    let nestgate_config = PrimalConfig {
        primal_type: PrimalType::NestGate,
        enabled: true,
        priority: 1,
        config: HashMap::new(),
    };
    child_biome_2.add_primal("nestgate".to_string(), nestgate_config).unwrap();
    
    // Add child biomes to parent
    parent_biome.add_child_biome("child-1".to_string(), child_biome_1).unwrap();
    parent_biome.add_child_biome("child-2".to_string(), child_biome_2).unwrap();
    
    // Activate parent (should activate children)
    let result = parent_biome.activate();
    assert!(result.is_ok());
    
    // Check that all biomes are active
    assert_eq!(parent_biome.state(), BiomeState::Active);
    assert!(parent_biome.child_biome_active("child-1"));
    assert!(parent_biome.child_biome_active("child-2"));
    
    // Test recursive health checking
    let health = parent_biome.recursive_health_check().unwrap();
    assert_eq!(health.overall_status, HealthStatus::Healthy);
    assert_eq!(health.child_statuses.len(), 2);
}

