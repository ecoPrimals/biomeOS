//! Unit tests for the biomeos-core primal module

use biomeos_core::primal::*;
use biomeos_core::{PrimalType, PrimalId, BiomeResult, HealthStatus, PrimalResourceLimits};
use std::collections::HashMap;
use chrono::Utc;
use uuid::Uuid;

#[test]
fn test_primal_type_creation() {
    let primal_type1: PrimalType = "songbird".to_string();
    let primal_type2: PrimalType = "toadstool".to_string();
    let primal_type3: PrimalType = "nestgate".to_string();
    let primal_type4: PrimalType = "squirrel".to_string();
    let primal_type5: PrimalType = "beardog".to_string();
    
    assert_eq!(primal_type1, "songbird");
    assert_eq!(primal_type2, "toadstool");
    assert_eq!(primal_type3, "nestgate");
    assert_eq!(primal_type4, "squirrel");
    assert_eq!(primal_type5, "beardog");
}

#[test]
fn test_capability_creation() {
    let capability = Capability {
        name: "service-discovery".to_string(),
        version: "1.0.0".to_string(),
        description: "Provides service discovery functionality".to_string(),
        parameters: HashMap::new(),
    };
    
    assert_eq!(capability.name, "service-discovery");
    assert_eq!(capability.version, "1.0.0");
    assert_eq!(capability.description, "Provides service discovery functionality");
    assert!(capability.parameters.is_empty());
}

#[test]
fn test_capability_parameter_creation() {
    let param = CapabilityParameter {
        param_type: "string".to_string(),
        required: true,
        default: Some(serde_json::Value::String("localhost".to_string())),
        description: "Host to connect to".to_string(),
        validation: None,
    };
    
    assert_eq!(param.param_type, "string");
    assert!(param.required);
    assert!(param.default.is_some());
    assert_eq!(param.description, "Host to connect to");
    assert!(param.validation.is_none());
}

#[test]
fn test_primal_dependency_creation() {
    let dependency = PrimalDependency {
        capability: "service-discovery".to_string(),
        min_version: "1.0.0".to_string(),
        optional: false,
        fallback: Some("local-discovery".to_string()),
    };
    
    assert_eq!(dependency.capability, "service-discovery");
    assert_eq!(dependency.min_version, "1.0.0");
    assert!(!dependency.optional);
    assert_eq!(dependency.fallback, Some("local-discovery".to_string()));
}

#[test]
fn test_primal_config_creation() {
    let mut config = PrimalConfig {
        settings: HashMap::new(),
        network: NetworkConfig {
            host: "localhost".to_string(),
            port: Some(8080),
            tls: None,
            discovery: Vec::new(),
        },
        security: SecurityConfig {
            auth_method: "none".to_string(),
            credentials: HashMap::new(),
            access_rules: Vec::new(),
        },
        resources: ResourceLimits {
            max_memory_mb: Some(4096),
            max_cpu: Some(2.0),
            max_disk_mb: Some(10240),
            max_bandwidth_mbps: Some(100),
        },
    };
    
    config.settings.insert("listen_port".to_string(), serde_json::Value::String("8080".to_string()));
    config.settings.insert("log_level".to_string(), serde_json::Value::String("info".to_string()));
    
    assert_eq!(config.network.host, "localhost");
    assert_eq!(config.network.port, Some(8080));
    assert_eq!(config.resources.max_memory_mb, Some(4096));
    assert_eq!(config.resources.max_cpu, Some(2.0));
    assert_eq!(config.settings.len(), 2);
}

#[test]
fn test_capability_request_creation() {
    let mut parameters = HashMap::new();
    parameters.insert("service_name".to_string(), serde_json::Value::String("test-service".to_string()));
    parameters.insert("namespace".to_string(), serde_json::Value::String("default".to_string()));
    
    let request = CapabilityRequest {
        request_id: Uuid::new_v4(),
        parameters,
        context: RequestContext {
            requesting_primal: "test-requester".to_string(),
            principal: "test-user".to_string(),
            timestamp: Utc::now(),
            correlation_id: Some("req-123".to_string()),
        },
    };
    
    assert_eq!(request.parameters.len(), 2);
    assert_eq!(request.context.principal, "test-user");
    assert_eq!(request.context.correlation_id, Some("req-123".to_string()));
}

#[test]
fn test_capability_response_success() {
    let mut metadata = HashMap::new();
    metadata.insert("primal_id".to_string(), serde_json::Value::String("songbird-1".to_string()));
    
    let response = CapabilityResponse {
        request_id: Uuid::new_v4(),
        success: true,
        data: Some(serde_json::Value::String("operation completed".to_string())),
        error: None,
        metadata,
    };
    
    assert!(response.success);
    assert!(response.data.is_some());
    assert!(response.error.is_none());
    assert_eq!(response.metadata.len(), 1);
}

#[test]
fn test_capability_response_failure() {
    let response = CapabilityResponse {
        request_id: Uuid::new_v4(),
        success: false,
        data: None,
        error: Some("Operation failed".to_string()),
        metadata: HashMap::new(),
    };
    
    assert!(!response.success);
    assert!(response.data.is_none());
    assert!(response.error.is_some());
    assert_eq!(response.error.unwrap(), "Operation failed");
}

#[test]
fn test_primal_event_creation() {
    let event = PrimalEvent {
        id: Uuid::new_v4(),
        event_type: "service.started".to_string(),
        source: "songbird-1".to_string(),
        target: Some("nestgate-1".to_string()),
        timestamp: Utc::now(),
        payload: serde_json::Value::Object(serde_json::Map::new()),
    };
    
    assert_eq!(event.event_type, "service.started");
    assert_eq!(event.source, "songbird-1");
    assert_eq!(event.target, Some("nestgate-1".to_string()));
    assert!(event.payload.is_object());
}

#[test]
fn test_primal_metrics_creation() {
    let metrics = PrimalMetrics {
        primal_id: "test-primal".to_string(),
        timestamp: Utc::now(),
        resources: ResourceMetrics {
            memory_mb: 512.0,
            cpu_usage: 0.25,
            disk_mb: 1024.0,
            bandwidth_mbps: 10.0,
        },
        performance: PerformanceMetrics {
            requests_per_second: 50.0,
            avg_response_time_ms: 100.0,
            error_rate: 0.01,
            active_connections: 25,
        },
        custom: HashMap::new(),
    };
    
    assert_eq!(metrics.primal_id, "test-primal");
    assert_eq!(metrics.resources.memory_mb, 512.0);
    assert_eq!(metrics.resources.cpu_usage, 0.25);
    assert_eq!(metrics.resources.disk_mb, 1024.0);
    assert_eq!(metrics.resources.bandwidth_mbps, 10.0);
    assert_eq!(metrics.performance.requests_per_second, 50.0);
    assert_eq!(metrics.performance.avg_response_time_ms, 100.0);
    assert_eq!(metrics.performance.error_rate, 0.01);
    assert_eq!(metrics.performance.active_connections, 25);
    assert!(metrics.custom.is_empty());
}

#[test]
fn test_resource_metrics_creation() {
    let metrics = ResourceMetrics {
        memory_mb: 1024.0,
        cpu_usage: 0.75,
        disk_mb: 2048.0,
        bandwidth_mbps: 50.0,
    };
    
    assert_eq!(metrics.memory_mb, 1024.0);
    assert_eq!(metrics.cpu_usage, 0.75);
    assert_eq!(metrics.disk_mb, 2048.0);
    assert_eq!(metrics.bandwidth_mbps, 50.0);
}

#[test]
fn test_performance_metrics_creation() {
    let metrics = PerformanceMetrics {
        requests_per_second: 100.0,
        avg_response_time_ms: 50.0,
        error_rate: 0.005,
        active_connections: 50,
    };
    
    assert_eq!(metrics.requests_per_second, 100.0);
    assert_eq!(metrics.avg_response_time_ms, 50.0);
    assert_eq!(metrics.error_rate, 0.005);
    assert_eq!(metrics.active_connections, 50);
}

