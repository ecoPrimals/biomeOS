#[test]
fn test_primal_metrics_serialization() {
    let metrics = PrimalMetrics {
        primal_id: "test-primal".to_string(),
        timestamp: Utc::now(),
        resources: ResourceMetrics {
            memory_mb: 1024.0,
            cpu_usage: 0.5,
            disk_mb: 2048.0,
            bandwidth_mbps: 100.0,
        },
        performance: PerformanceMetrics {
            requests_per_second: 50.0,
            avg_response_time_ms: 100.0,
            error_rate: 0.01,
            active_connections: 25,
        },
        custom: HashMap::new(),
    };
    
    // Test JSON serialization
    let json = serde_json::to_string(&metrics);
    assert!(json.is_ok());
    
    // Test deserialization
    let deserialized: Result<PrimalMetrics, _> = serde_json::from_str(&json.unwrap());
    assert!(deserialized.is_ok());
    
    let deserialized_metrics = deserialized.unwrap();
    assert_eq!(deserialized_metrics.primal_id, "test-primal");
    assert_eq!(deserialized_metrics.resources.memory_mb, 1024.0);
    assert_eq!(deserialized_metrics.performance.requests_per_second, 50.0);
}

#[test]
fn test_tls_config_creation() {
    let tls_config = TlsConfig {
        cert_path: "/path/to/cert.pem".to_string(),
        key_path: "/path/to/key.pem".to_string(),
        ca_path: Some("/path/to/ca.pem".to_string()),
    };
    
    assert_eq!(tls_config.cert_path, "/path/to/cert.pem");
    assert_eq!(tls_config.key_path, "/path/to/key.pem");
    assert_eq!(tls_config.ca_path, Some("/path/to/ca.pem".to_string()));
}

#[test]
fn test_access_rule_creation() {
    let rule = AccessRule {
        subject: "user:alice".to_string(),
        action: "read".to_string(),
        resource: "/api/v1/*".to_string(),
        effect: "allow".to_string(),
    };
    
    assert_eq!(rule.subject, "user:alice");
    assert_eq!(rule.action, "read");
    assert_eq!(rule.resource, "/api/v1/*");
    assert_eq!(rule.effect, "allow");
}

#[test]
fn test_network_config_defaults() {
    let config = NetworkConfig::default();
    
    assert_eq!(config.host, "localhost");
    assert!(config.port.is_none());
    assert!(config.tls.is_none());
    assert!(config.discovery.is_empty());
}

#[test]
fn test_security_config_defaults() {
    let config = SecurityConfig::default();
    
    assert_eq!(config.auth_method, "none");
    assert!(config.credentials.is_empty());
    assert!(config.access_rules.is_empty());
}

#[test]
fn test_request_context_creation() {
    let context = RequestContext {
        requesting_primal: "test-primal".to_string(),
        principal: "test-user".to_string(),
        timestamp: Utc::now(),
        correlation_id: Some("corr-123".to_string()),
    };
    
    assert_eq!(context.requesting_primal, "test-primal");
    assert_eq!(context.principal, "test-user");
    assert_eq!(context.correlation_id, Some("corr-123".to_string()));
}

#[test]
fn test_capability_with_parameters() {
    let mut parameters = HashMap::new();
    parameters.insert("host".to_string(), CapabilityParameter {
        param_type: "string".to_string(),
        required: true,
        default: Some(serde_json::Value::String("localhost".to_string())),
        description: "Host to connect to".to_string(),
        validation: None,
    });
    
    let capability = Capability {
        name: "database-connection".to_string(),
        version: "1.0.0".to_string(),
        description: "Database connection capability".to_string(),
        parameters,
    };
    
    assert_eq!(capability.name, "database-connection");
    assert_eq!(capability.parameters.len(), 1);
    assert!(capability.parameters.contains_key("host"));
}

#[test]
fn test_custom_metrics_in_primal_metrics() {
    let mut custom_metrics = HashMap::new();
    custom_metrics.insert("cache_hit_rate".to_string(), serde_json::Value::from(0.95));
    custom_metrics.insert("queue_length".to_string(), serde_json::Value::from(5));
    
    let metrics = PrimalMetrics {
        primal_id: "test-primal".to_string(),
        timestamp: Utc::now(),
        resources: ResourceMetrics {
            memory_mb: 1024.0,
            cpu_usage: 0.5,
            disk_mb: 2048.0,
            bandwidth_mbps: 100.0,
        },
        performance: PerformanceMetrics {
            requests_per_second: 50.0,
            avg_response_time_ms: 100.0,
            error_rate: 0.01,
            active_connections: 25,
        },
        custom: custom_metrics,
    };
    
    assert_eq!(metrics.custom.len(), 2);
    assert!(metrics.custom.contains_key("cache_hit_rate"));
    assert!(metrics.custom.contains_key("queue_length"));
} 