#[test]
fn test_primal_type_metadata_creation() {
    let metadata = PrimalTypeMetadata {
        primal_type: "songbird".to_string(),
        name: "Songbird".to_string(),
        description: "Service discovery and load balancing".to_string(),
        version: "1.0.0".to_string(),
        author: "biomeOS Team".to_string(),
        capabilities: vec![
            Capability {
                name: "service-discovery".to_string(),
                version: "1.0.0".to_string(),
                description: "Service discovery capability".to_string(),
                parameters: HashMap::new(),
            },
            Capability {
                name: "load-balancing".to_string(),
                version: "1.0.0".to_string(),
                description: "Load balancing capability".to_string(),
                parameters: HashMap::new(),
            },
        ],
        config_schema: serde_json::json!({
            "type": "object",
            "properties": {
                "host": {"type": "string"},
                "port": {"type": "number"}
            }
        }),
    };
    
    assert_eq!(metadata.name, "Songbird");
    assert_eq!(metadata.description, "Service discovery and load balancing");
    assert_eq!(metadata.version, "1.0.0");
    assert_eq!(metadata.capabilities.len(), 2);
    assert_eq!(metadata.author, "biomeOS Team");
    assert!(metadata.config_schema.is_object());
}

#[test]
fn test_primal_resource_limits_creation() {
    let limits = ResourceLimits {
        max_memory_mb: Some(4096),
        max_cpu: Some(4.0),
        max_disk_mb: Some(20480),
        max_bandwidth_mbps: Some(200),
    };
    
    assert_eq!(limits.max_memory_mb, Some(4096));
    assert_eq!(limits.max_cpu, Some(4.0));
    assert_eq!(limits.max_disk_mb, Some(20480));
    assert_eq!(limits.max_bandwidth_mbps, Some(200));
}

#[test]
fn test_primal_resource_limits_none() {
    let limits = ResourceLimits {
        max_memory_mb: None,
        max_cpu: None,
        max_disk_mb: None,
        max_bandwidth_mbps: None,
    };
    
    assert!(limits.max_memory_mb.is_none());
    assert!(limits.max_cpu.is_none());
    assert!(limits.max_disk_mb.is_none());
    assert!(limits.max_bandwidth_mbps.is_none());
}

#[test]
fn test_primal_config_serialization() {
    let config = PrimalConfig {
        settings: HashMap::new(),
        network: NetworkConfig {
            host: "localhost".to_string(),
            port: Some(8080),
            tls: None,
            discovery: Vec::new(),
        },
        security: SecurityConfig {
            auth_method: "none".to_string(),
            credentials: HashMap::new(),
            access_rules: Vec::new(),
        },
        resources: ResourceLimits {
            max_memory_mb: Some(4096),
            max_cpu: Some(2.0),
            max_disk_mb: Some(10240),
            max_bandwidth_mbps: Some(100),
        },
    };
    
    // Test JSON serialization
    let json = serde_json::to_string(&config);
    assert!(json.is_ok());
    
    // Test deserialization
    let deserialized: Result<PrimalConfig, _> = serde_json::from_str(&json.unwrap());
    assert!(deserialized.is_ok());
    
    let deserialized_config = deserialized.unwrap();
    assert_eq!(deserialized_config.network.host, "localhost");
    assert_eq!(deserialized_config.network.port, Some(8080));
    assert_eq!(deserialized_config.resources.max_memory_mb, Some(4096));
    assert_eq!(deserialized_config.resources.max_cpu, Some(2.0));
}

#[test]
fn test_capability_request_serialization() {
    let request = CapabilityRequest {
        request_id: Uuid::new_v4(),
        parameters: HashMap::new(),
        context: RequestContext {
            requesting_primal: "test-requester".to_string(),
            principal: "test-user".to_string(),
            timestamp: Utc::now(),
            correlation_id: Some("test-correlation".to_string()),
        },
    };
    
    // Test JSON serialization
    let json = serde_json::to_string(&request);
    assert!(json.is_ok());
    
    // Test deserialization
    let deserialized: Result<CapabilityRequest, _> = serde_json::from_str(&json.unwrap());
    assert!(deserialized.is_ok());
    
    let deserialized_request = deserialized.unwrap();
    assert_eq!(deserialized_request.context.principal, "test-user");
    assert_eq!(deserialized_request.context.correlation_id, Some("test-correlation".to_string()));
}

#[test]
fn test_capability_response_serialization() {
