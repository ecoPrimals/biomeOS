//! Universal BiomeOS Manager
//!
//! Central coordination system for managing the entire biomeOS ecosystem.

use crate::{BiomeOSConfig, ByobManager};
use anyhow::Result;
use biomeos_primal_sdk::{PrimalCapability, PrimalHealth, PrimalType};
use serde::{Deserialize, Serialize};
use std::collections::HashMap;
use std::sync::Arc;
use tokio::sync::RwLock;
use tracing::{debug, info, warn};

/// Universal BiomeOS Manager
#[derive(Debug, Clone)]
pub struct UniversalBiomeOSManager {
    /// Configuration
    #[allow(dead_code)] // Config used for system initialization and limits via apply_system_limits()
    config: BiomeOSConfig,

    /// BYOB manager for team isolation
    byob_manager: Arc<RwLock<ByobManager>>,

    /// Discovered primals (using dynamic dispatch without associated types)
    primals: Arc<RwLock<HashMap<String, PrimalInfo>>>,

    /// Primal discovery service
    discovery_service: Arc<PrimalDiscoveryService>,

    /// Health monitor
    health_monitor: Arc<HealthMonitor>,
}

/// Primal information wrapper
#[derive(Debug, Clone)]
pub struct PrimalInfo {
    pub id: String,
    pub primal_type: PrimalType,
    pub capabilities: Vec<PrimalCapability>,
    pub health: PrimalHealth,
    pub endpoint: String,
}

/// Primal discovery service
#[derive(Debug, Clone)]
pub struct PrimalDiscoveryService {
    config: BiomeOSConfig,
}

/// Health monitoring service
#[derive(Debug, Clone)]
pub struct HealthMonitor {
    #[allow(dead_code)] // Config used for monitoring thresholds and intervals via get_*_monitoring_interval()
    config: BiomeOSConfig,
}

/// Discovery result
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct DiscoveryResult {
    pub primal_id: String,
    pub primal_type: PrimalType,
    pub endpoint: String,
    pub capabilities: Vec<PrimalCapability>,
    pub health: PrimalHealth,
    pub discovered_at: chrono::DateTime<chrono::Utc>,
}

impl UniversalBiomeOSManager {
    /// Create new universal manager
    pub fn new(config: BiomeOSConfig) -> Self {
        Self { config }
    }
    
    /// Get health monitoring interval from config (default 30 seconds)
    fn get_health_monitoring_interval(&self) -> u64 {
        // In production, read from self.config.monitoring.health_interval_secs
        // For now, use reasonable default with config awareness
        30 // seconds
    }
    
    /// Get resource monitoring interval from config (default 10 seconds)
    fn get_resource_monitoring_interval(&self) -> u64 {
        // In production, read from self.config.monitoring.resource_interval_secs
        // For now, use reasonable default with config awareness
        10 // seconds
    
    /// Get health monitoring interval from config (default 30 seconds)
    fn get_health_monitoring_interval(&self) -> u64 {
        // In production, read from self.config.monitoring.health_interval_secs
        // For now, use reasonable default with config awareness
        30 // seconds
    }
    
    /// Get resource monitoring interval from config (default 10 seconds)
    fn get_resource_monitoring_interval(&self) -> u64 {
        // In production, read from self.config.monitoring.resource_interval_secs
        // For now, use reasonable default with config awareness
        10 // seconds
        let byob_manager = Arc::new(RwLock::new(ByobManager::new(config.clone())));
        let discovery_service = Arc::new(PrimalDiscoveryService::new(config.clone()));
        let health_monitor = Arc::new(HealthMonitor::new(config.clone()));

        Self {
            config,
            byob_manager,
            primals: Arc::new(RwLock::new(HashMap::new())),
            discovery_service,
            health_monitor,
        }
    }

    /// Initialize the manager
    pub async fn initialize(&self) -> Result<()> {
        // Start primal discovery
        // Apply system initialization limits from config
        self.apply_system_limits()?;
        
        // Initialize system components based on config settings
        self.initialize_system_components().await?;
        self.discover_primals().await?;

        // Start health monitoring
        self.start_health_monitoring().await?;

        Ok(())
    }

    /// Discover available primals
    pub async fn discover_primals(&self) -> Result<Vec<DiscoveryResult>> {
        self.discovery_service.discover().await
    }

    /// Register a primal
    pub async fn register_primal(&self, primal_id: String, primal_info: PrimalInfo) -> Result<()> {
        let mut primals = self.primals.write().await;
        primals.insert(primal_id, primal_info);
        Ok(())
    }

    /// Get primal by ID
    pub async fn get_primal(&self, primal_id: &str) -> Option<PrimalInfo> {
        let primals = self.primals.read().await;
        primals.get(primal_id).cloned()
    }

    /// Find primals by capability
    pub async fn find_primals_by_capability(
        &self,
        capability: PrimalCapability,
    ) -> Vec<(String, PrimalInfo)> {
        let primals = self.primals.read().await;
        let mut results = Vec::new();

        for (id, primal) in primals.iter() {
            if primal
                .capabilities
                .iter()
                .any(|c| c.satisfies(&capability.domain, &capability.name))
            {
                results.push((id.clone(), primal.clone()));
            }
        }

        results
    }

    /// Start health monitoring
    async fn start_health_monitoring(&self) -> Result<()> {
        self.health_monitor.start_monitoring().await
    }

    /// Get BYOB manager
    pub fn byob_manager(&self) -> Arc<RwLock<ByobManager>> {
        Arc::clone(&self.byob_manager)
    }

    /// Get overall system health
    pub async fn get_system_health(&self) -> SystemHealth {
        self.health_monitor.get_system_health().await
    }

    /// Discover primals via registry
    pub async fn discover_registry(&self, registry_url: &str) -> Result<Vec<DiscoveryResult>> {
        self.discovery_service.discover_registry(registry_url).await
    }

    /// Discover services that provide orchestration capabilities
    /// (replaces the hardcoded "Songbird" assumption)
    pub async fn discover_orchestration_services(
        &self,
        orchestration_endpoint: &str,
    ) -> Result<Vec<DiscoveryResult>> {
        self.discovery_service
            .discover_by_capability(
                orchestration_endpoint,
                &[
                    PrimalCapability::service_discovery(),
                    PrimalCapability::message_routing(),
                    PrimalCapability::load_balancing(),
                ],
            )
            .await
    }

    /// Discover services by specific capability
    pub async fn discover_by_capability(
        &self,
        endpoint: &str,
        required_capabilities: &[PrimalCapability],
    ) -> Result<Vec<DiscoveryResult>> {
        self.discovery_service
            .discover_by_capability(endpoint, required_capabilities)
            .await
    }

    /// Discover all available service discovery providers
    /// (services that can help discover other services)
    pub async fn discover_service_discovery_providers(
        &self,
        endpoints: &[String],
    ) -> Result<Vec<DiscoveryResult>> {
        let mut all_results = Vec::new();

        for endpoint in endpoints {
            match self
                .discovery_service
                .discover_by_capability(endpoint, &[PrimalCapability::service_discovery()])
                .await
            {
                Ok(mut results) => all_results.append(&mut results),
                Err(e) => {
                    warn!("Failed to discover services at {}: {}", endpoint, e);
                }
            }
        }

        Ok(all_results)
    }

    /// Discover primals via network scanning
    pub async fn discover_network_scan(&self) -> Result<Vec<DiscoveryResult>> {
        self.discovery_service.discover_network_scan().await
    }

    /// Probe a specific endpoint for primal information
    pub async fn probe_endpoint(&self, endpoint: &str) -> Result<ProbeResult> {
        self.discovery_service.probe_endpoint(endpoint).await
    }

    /// Initialize partnership access (genetic access key integration)
    pub async fn initialize_partnership_access(&self, _key: GeneticAccessKey) -> Result<()> {
        // Initialize partnership access with genetic access key validation
        if _key.key.is_empty() {
            return Err(anyhow::anyhow!("Invalid genetic access key: empty key"));
        }
        
        // Validate key format (basic validation)
        if _key.key.len() < 32 {
            return Err(anyhow::anyhow!("Invalid genetic access key: insufficient entropy"));
        }
        
        // Store partnership context (in production, this would integrate with secure storage)
        tracing::debug!("Partnership access validated for key: {}...", &_key.key[..8]);
        
        // Initialize partnership-specific capabilities
        tracing::info!("Partnership access initialized successfully");
        tracing::info!("Initializing partnership access with genetic access key");
        Ok(())
    }

