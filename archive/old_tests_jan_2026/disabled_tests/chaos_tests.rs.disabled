//! Chaos Engineering and Fault Injection Tests
//!
//! These tests verify BiomeOS resilience under adverse conditions:
//! - Network failures and timeouts
//! - Partial service outages
//! - Invalid data and malformed responses
//! - Race conditions and concurrency issues
//! - Resource exhaustion scenarios

use biomeos_core::clients::songbird::*;
use biomeos_core::discovery_bootstrap::DiscoveryBootstrap;
use biomeos_core::primal_client::PrimalClient;
use serde_json::json;
use std::time::Duration;
use wiremock::{
    matchers::{method, path},
    Mock, MockServer, ResponseTemplate,
};

// ============================================================================
// Chaos: Network Failures
// ============================================================================

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_service_completely_unavailable() {
    // No mock server running - service unavailable
    let client = SongbirdClient::new("http://localhost:99999"); // Invalid port

    let result = client.health_check().await;
    assert!(result.is_err());

    assert!(!client.is_available().await);
}

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_network_timeout() {
    let mock_server = MockServer::start().await;

    // Simulate slow/hanging endpoint
    Mock::given(method("GET"))
        .and(path("/health"))
        .respond_with(
            ResponseTemplate::new(200)
                .set_delay(Duration::from_secs(30)) // Very slow
                .set_body_json(json!({"status": "healthy"})),
        )
        .mount(&mock_server)
        .await;

    let client = SongbirdClient::new(mock_server.uri());

    // Request with short timeout should fail
    let result = tokio::time::timeout(Duration::from_millis(100), client.health_check()).await;

    assert!(result.is_err()); // Should timeout
}

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_intermittent_connectivity() {
    let _mock_server = MockServer::start().await;

    // Test intermittent connectivity with two separate servers
    let mock_server_fail = MockServer::start().await;
    let _mock_server_ok = MockServer::start().await;

    // First server fails (network blip)
    Mock::given(method("GET"))
        .and(path("/api/v1/services/query/compute"))
        .respond_with(ResponseTemplate::new(503)) // Service unavailable
        .mount(&mock_server_fail)
        .await;

    // Second server succeeds
    Mock::given(method("GET"))
        .and(path("/api/v1/services/query/compute"))
        .respond_with(ResponseTemplate::new(200).set_body_json(json!([])))
        .mount(&_mock_server_ok)
        .await;

    // First attempt with failing server
    let client_fail = SongbirdClient::new(mock_server_fail.uri());
    let first = client_fail.discover_by_capability("compute").await;
    assert!(first.is_err());

    // Retry with working server (simulates recovery)
    let client_ok = SongbirdClient::new(_mock_server_ok.uri());
    let second = client_ok.discover_by_capability("compute").await;
    assert!(second.is_ok());
}

