        .await;

    let client = SongbirdClient::new(mock_server.uri());
    let result = client.discover_by_capability("compute").await;

    assert!(result.is_err());
}

// ============================================================================
// Chaos: Partial Service Outages
// ============================================================================

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_some_services_down() {
    let mock_server = MockServer::start().await;

    // Discovery returns mix of healthy and unhealthy services
    Mock::given(method("GET"))
        .and(path("/api/v1/services/query/compute"))
        .respond_with(ResponseTemplate::new(200).set_body_json(json!([
                {
                    "service_id": "compute-healthy",
                    "service_name": "healthy-service",
                    "endpoint": "http://healthy:8080",
                    "capabilities": ["compute"],
                    "metadata": {"version": "1.0.0", "tags": []}
                },
                {
                    "service_id": "compute-unhealthy",
                    "service_name": "unhealthy-service",
                    "endpoint": "http://unreachable:8080", // This endpoint doesn't exist
                    "capabilities": ["compute"],
                    "metadata": {"version": "1.0.0", "tags": []}
                }
        ])))
        .mount(&mock_server)
        .await;

    let client = SongbirdClient::new(mock_server.uri());
    let services = client.discover_by_capability("compute").await.unwrap();

    // Discovery succeeds, returns all services (health check is separate)
    assert_eq!(services.len(), 2);

    // Client code must handle individual service failures
    // (This test verifies discovery doesn't fail if some services are down)
}

// ============================================================================
// Chaos: Race Conditions and Concurrency
// ============================================================================

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_concurrent_registrations() {
    let mock_server = MockServer::start().await;

    // Simple mock that always succeeds (testing client concurrency handling)
    Mock::given(method("POST"))
        .and(path("/api/v1/services/register"))
        .respond_with(ResponseTemplate::new(200).set_body_json(json!({
            "service_id": "service-concurrent"
        })))
        .mount(&mock_server)
        .await;

    let client = SongbirdClient::new(mock_server.uri());

    // Spawn multiple concurrent registration requests
    let mut handles = vec![];
    for i in 0..10 {
        let client_clone = client.clone();
        let handle = tokio::spawn(async move {
            let registration = ServiceRegistration {
                service_name: format!("concurrent-service-{}", i),
                capabilities: vec!["test".to_string()],
                endpoint: format!("http://service-{}:8080", i),
                metadata: ServiceMetadata {
                    version: "1.0.0".to_string(),
                    location: None,
                    tags: vec![],
                },
            };
            client_clone.register_service(&registration).await
        });
        handles.push(handle);
    }

    // All should succeed without race conditions
    for handle in handles {
        let result = handle.await.unwrap();
        assert!(result.is_ok());
    }
}

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_concurrent_discoveries() {
    let mock_server = MockServer::start().await;

    Mock::given(method("GET"))
        .and(path("/api/v1/services/query/compute"))
        .respond_with(ResponseTemplate::new(200).set_body_json(json!([
            {
                "service_id": "compute-1",
                "service_name": "compute-service",
                "endpoint": "http://compute:8080",
                "capabilities": ["compute"],
                "metadata": {"version": "1.0.0", "tags": []}
            }
        ])))
        .mount(&mock_server)
        .await;

    let client = SongbirdClient::new(mock_server.uri());

    // Spawn many concurrent discovery requests
    let mut handles = vec![];
    for _ in 0..50 {
        let client_clone = client.clone();
        let handle =
            tokio::spawn(async move { client_clone.discover_by_capability("compute").await });
        handles.push(handle);
    }

    // All should succeed without conflicts
    for handle in handles {
        let result = handle.await.unwrap();
        assert!(result.is_ok());
        let services = result.unwrap();
        assert_eq!(services.len(), 1);
    }
}

// ============================================================================
// Chaos: Resource Exhaustion
// ============================================================================

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_large_service_list() {
    let mock_server = MockServer::start().await;

    // Generate large list of services
    let large_list: Vec<_> = (0..1000)
        .map(|i| {
            json!({
                "service_id": format!("service-{}", i),
                "service_name": format!("service-name-{}", i),
                "endpoint": format!("http://service-{}:8080", i),
                "capabilities": ["compute"],
                "metadata": {"version": "1.0.0", "tags": []}
            })
        })
        .collect();

    Mock::given(method("GET"))
        .and(path("/api/v1/services/query/compute"))
        .respond_with(ResponseTemplate::new(200).set_body_json(large_list))
        .mount(&mock_server)
        .await;

    let client = SongbirdClient::new(mock_server.uri());
    let services = client.discover_by_capability("compute").await.unwrap();

    // Should handle large lists without issues
    assert_eq!(services.len(), 1000);
}

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_deeply_nested_metadata() {
    let mock_server = MockServer::start().await;

    // Service with complex nested metadata
    Mock::given(method("GET"))
        .and(path("/api/v1/services/query/compute"))
        .respond_with(ResponseTemplate::new(200).set_body_json(json!([
                {
                    "service_id": "complex",
                    "service_name": "complex-service",
                    "endpoint": "http://complex:8080",
                    "capabilities": ["compute"],
                    "metadata": {
                        "version": "1.0.0",
                        "tags": vec!["a"; 100], // Many tags
                        "custom_field": json!({"nested": {"deeply": {"value": "test"}}})
                    }
                }
        ])))
        .mount(&mock_server)
        .await;

    let client = SongbirdClient::new(mock_server.uri());
    let result = client.discover_by_capability("compute").await;

    // Should handle complex metadata gracefully
    assert!(result.is_ok());
}

// ============================================================================
// Chaos: Bootstrap Discovery Failures
// ============================================================================

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_no_discovery_methods_available() {
    // Clear all environment variables
    let saved_discovery = std::env::var("DISCOVERY_ENDPOINT").ok();
    let saved_songbird = std::env::var("SONGBIRD_ENDPOINT").ok();

    std::env::remove_var("DISCOVERY_ENDPOINT");
    std::env::remove_var("SONGBIRD_ENDPOINT");

    let bootstrap = DiscoveryBootstrap::new("universal-adapter");
    let result = bootstrap.find_universal_adapter().await;

    // Restore
    if let Some(val) = saved_discovery {
        std::env::set_var("DISCOVERY_ENDPOINT", val);
    }
    if let Some(val) = saved_songbird {
        std::env::set_var("SONGBIRD_ENDPOINT", val);
    }

    // Should fail gracefully with helpful error
    assert!(result.is_err());
    let error = result.unwrap_err().to_string();
    assert!(error.contains("No universal adapter found"));
    assert!(error.contains("DISCOVERY_ENDPOINT"));
}

