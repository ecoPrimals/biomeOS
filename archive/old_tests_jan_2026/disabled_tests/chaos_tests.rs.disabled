#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_service_registration_missing_service_id() {
    let mock_server = MockServer::start().await;

    // Response missing service_id
    Mock::given(method("POST"))
        .and(path("/api/v1/services/register"))
        .respond_with(ResponseTemplate::new(200).set_body_json(json!({
            "status": "registered"
            // Missing: service_id
        })))
        .mount(&mock_server)
        .await;

    let client = SongbirdClient::new(mock_server.uri());
    let registration = ServiceRegistration {
        service_name: "test".to_string(),
        capabilities: vec!["test".to_string()],
        endpoint: "http://test:8080".to_string(),
        metadata: ServiceMetadata {
            version: "1.0.0".to_string(),
            location: None,
            tags: vec![],
        },
    };

    let result = client.register_service(&registration).await;
    assert!(result.is_err());
}

// ============================================================================
// Chaos: Geographic Edge Cases
// ============================================================================

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_location_at_poles() {
    // Test distance calculation at extreme latitudes
    let north_pole = Location {
        latitude: 90.0,
        longitude: 0.0,
    };

    // Distance between poles should be roughly half Earth's circumference
    let distance = north_pole.distance_to(-90.0, 0.0);
    assert!(distance > 19000.0 && distance < 21000.0); // ~20,000 km
}

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_location_across_date_line() {
    // Test distance across international date line
    let west = Location {
        latitude: 0.0,
        longitude: 179.0,
    };

    // Should be ~222 km apart, not 358 degrees
    let distance = west.distance_to(0.0, -179.0);
    assert!(distance < 500.0); // Should be small
}

// ============================================================================
// Chaos: Stress Test
// ============================================================================

#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
async fn test_chaos_rapid_fire_requests() {
    let mock_server = MockServer::start().await;

    Mock::given(method("GET"))
        .and(path("/health"))
        .respond_with(ResponseTemplate::new(200).set_body_json(json!({"status": "healthy"})))
        .mount(&mock_server)
        .await;

    let client = SongbirdClient::new(mock_server.uri());

    // Fire 100 requests as fast as possible
    let mut handles = vec![];
    for _ in 0..100 {
        let client_clone = client.clone();
        let handle = tokio::spawn(async move { client_clone.health_check().await });
        handles.push(handle);
    }

    // All should complete successfully
    let mut success_count = 0;
    for handle in handles {
        if let Ok(Ok(_)) = handle.await {
            success_count += 1;
        }
    }

    // Most should succeed (allow some to fail under extreme load)
    assert!(success_count >= 90);
}
