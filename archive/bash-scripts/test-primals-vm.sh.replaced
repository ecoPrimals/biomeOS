#!/usr/bin/env bash
#
# Test BiomeOS with Primals in VM
#

set -euo pipefail

ISO="${1:-dist/biomeos-20251227-165759.iso}"
ROOTFS="${2:-vm-testing/biomeos-with-primals.qcow2}"
LOG="/tmp/biomeos-primals-test.log"

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🚀 Booting BiomeOS with Primals"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ISO: $ISO"
echo "  Root FS: $ROOTFS"
echo "  Serial Log: $LOG"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "Starting VM..."
echo "(Press Ctrl+A then X to quit QEMU, or Ctrl+C to stop)"
echo ""

rm -f "$LOG"

qemu-system-x86_64 \
    -name "BiomeOS-With-Primals" \
    -cdrom "$ISO" \
    -drive file="$ROOTFS",format=qcow2,if=ide \
    -m 1G \
    -smp 2 \
    -serial file:"$LOG" \
    -display none \
    -nographic

