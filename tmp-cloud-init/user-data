#cloud-config
users:
  - name: biomeos
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - ssh-rsa  eastgate@pop-os

packages:
  - avahi-daemon
  - avahi-utils
  - curl

runcmd:
  - systemctl enable avahi-daemon
  - systemctl start avahi-daemon
  - mkdir -p /opt/biomeos
