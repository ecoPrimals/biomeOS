primals/
bin/tower

# plasmidBin local cache: keep directory structure, ignore all binaries
plasmidBin/beardog
plasmidBin/beardog-server
plasmidBin/nestgate
plasmidBin/songbird
plasmidBin/squirrel
plasmidBin/toadstool
