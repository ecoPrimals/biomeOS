
*~
/coverage/
# Coverage
# EXCEPT: Keep structure and version manifest
# IDE
.idea/
*.iso
*.log
*.pdb
plasmidBin/archive/**/*
!plasmidBin/archive/.gitkeep
!plasmidBin/MANIFEST.md
plasmidBin/neural-api-server
plasmidBin/beardog-server
plasmidBin/primals/*
!plasmidBin/primals/.gitkeep
# PlasmidBin - Stable deployment binaries (not tracked in git)
plasmidBin/tower/*
!plasmidBin/tower/.gitkeep
!plasmidBin/VERSION.txt
*.profdata
*.profraw
*.qcow2
**/*.rs.bk
# Rust build artifacts
*.swo
*.swp
/target/
target/

# Local binary directories (not tracked)
primals/
bin/
vm-images/*.img
vm-testing/*.qcow2
.vscode/

# Sensitive files (TRUE ecoBin v2.0 security)
*.key
*.pem
*.env
*secret*
*credential*
secrets/
certs/

# Identity and seed files (never commit)
.family.seed
.lineage.seed
.lineage.json
.beacon.seed
.known_beacons.json
.project-status

# Runtime data (generated at runtime, not source)
data/
tmp-cloud-init/
audit.log
command_history.json
command_journal.json

# Primal binaries (ELF/Mach-O - use genomeBin for distribution)
validation/primals/
base-spore/primals/
base-spore/.family.seed

# Archive (fossil record lives in ecoPrimals/archive/)
archive/
cloudflared
*.bak*/
plasmidBin/optimized/
chimeras/**/Cargo.lock
chimeras/**/target/
