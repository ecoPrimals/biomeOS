pixel8a-deploy/songbird
pixel8a-deploy/squirrel
pixel8a-deploy/nestgate
pixel8a-deploy/toadstool

# ── Generated visualizations (keep .dot/.json/.svg source) ───────────────────
visualizations/*.png

