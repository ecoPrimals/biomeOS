#!/usr/bin/env bash
# Mock Squirrel - Direct execution pattern

PORT=${PORT:-9010}

# Support --version flag
if [ "$1" = "--version" ]; then
    echo "squirrel-mock 1.0.0"
    exit 0
fi

# Support --help flag
if [ "$1" = "--help" ]; then
    echo "Squirrel AI/MCP Primal (Mock)"
    echo ""
    echo "Usage: squirrel-mock [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --version    Show version"
    echo "  --help       Show this help"
    echo ""
    echo "Environment:"
    echo "  PORT         Port to listen on (default: 9010)"
    exit 0
fi

echo "🐿️  Squirrel AI/MCP Primal (Mock) starting on port $PORT"
echo "   Interface: Direct execution (no subcommands)"
echo "   Port config: PORT environment variable"
echo ""

# Simple HTTP server that responds to health checks
python3 -c "
import http.server
import socketserver
import json

PORT = $PORT

class HealthHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/health':
            self.send_response(200)
            self.send_header('Content-type', 'application/json')
            self.end_headers()
            response = {
                'status': 'healthy',
                'primal': 'squirrel',
                'version': '1.0.0',
                'capabilities': ['ai', 'mcp']
            }
            self.wfile.write(json.dumps(response).encode())
        else:
            self.send_response(200)
            self.send_header('Content-type', 'text/plain')
            self.end_headers()
            self.wfile.write(b'Squirrel AI/MCP Primal (Mock)')
    
    def log_message(self, format, *args):
        return  # Suppress logs

with socketserver.TCPServer(('', PORT), HealthHandler) as httpd:
    print(f'✅ Squirrel listening on port {PORT}')
    print(f'   Health check: http://localhost:{PORT}/health')
    httpd.serve_forever()
"

