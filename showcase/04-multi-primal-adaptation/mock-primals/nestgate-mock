#!/usr/bin/env bash
# Mock NestGate - Subcommand pattern (service)

# Support --version flag
if [ "$1" = "--version" ]; then
    echo "nestgate-mock 1.0.0"
    exit 0
fi

# Support --help flag
if [ "$1" = "--help" ]; then
    echo "NestGate Storage Primal (Mock)"
    echo ""
    echo "Usage: nestgate-mock <COMMAND>"
    echo ""
    echo "Commands:"
    echo "  service      Start the storage service"
    echo ""
    echo "Options:"
    echo "  --version    Show version"
    echo "  --help       Show this help"
    exit 0
fi

# Require 'service' subcommand
if [ "$1" != "service" ]; then
    echo "Error: unrecognized subcommand '$1'"
    echo ""
    echo "Usage: nestgate-mock service"
    echo "Try 'nestgate-mock --help' for more information."
    exit 1
fi

PORT=${PORT:-9020}

echo "🪺 NestGate Storage Primal (Mock) starting on port $PORT"
echo "   Interface: Subcommand (service)"
echo "   Port config: PORT environment variable"
echo ""

# Simple HTTP server
python3 -c "
import http.server
import socketserver
import json

PORT = $PORT

class HealthHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/health':
            self.send_response(200)
            self.send_header('Content-type', 'application/json')
            self.end_headers()
            response = {
                'status': 'healthy',
                'primal': 'nestgate',
                'version': '1.0.0',
                'capabilities': ['storage', 'sovereignty']
            }
            self.wfile.write(json.dumps(response).encode())
        else:
            self.send_response(200)
            self.send_header('Content-type', 'text/plain')
            self.end_headers()
            self.wfile.write(b'NestGate Storage Primal (Mock)')
    
    def log_message(self, format, *args):
        return

with socketserver.TCPServer(('', PORT), HealthHandler) as httpd:
    print(f'✅ NestGate listening on port {PORT}')
    print(f'   Health check: http://localhost:{PORT}/health')
    httpd.serve_forever()
"

