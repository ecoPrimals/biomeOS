#!/usr/bin/env bash
# Mock ToadStool - Direct execution pattern

PORT=${PORT:-9030}

if [ "$1" = "--version" ]; then
    echo "toadstool-mock 1.0.0"
    exit 0
fi

if [ "$1" = "--help" ]; then
    echo "ToadStool Compute Primal (Mock)"
    echo "Usage: toadstool-mock [OPTIONS]"
    echo "Environment: PORT (default: 9030)"
    exit 0
fi

echo "🍄 ToadStool Compute Primal (Mock) starting on port $PORT"
echo "   Interface: Direct execution"
echo ""

python3 -c "
import http.server
import socketserver
import json

PORT = $PORT

class HealthHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/health':
            self.send_response(200)
            self.send_header('Content-type', 'application/json')
            self.end_headers()
            response = {
                'status': 'healthy',
                'primal': 'toadstool',
                'version': '1.0.0',
                'capabilities': ['compute', 'orchestration']
            }
            self.wfile.write(json.dumps(response).encode())
        else:
            self.send_response(200)
            self.send_header('Content-type', 'text/plain')
            self.end_headers()
            self.wfile.write(b'ToadStool Compute Primal (Mock)')
    
    def log_message(self, format, *args):
        return

with socketserver.TCPServer(('', PORT), HealthHandler) as httpd:
    print(f'✅ ToadStool listening on port {PORT}')
    print(f'   Health check: http://localhost:{PORT}/health')
    httpd.serve_forever()
"

